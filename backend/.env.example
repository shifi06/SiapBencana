# ── Database ──────────────────────────────────────────────────────
# Ganti dengan connection string PostgreSQL kamu (Neon, Supabase, RDS, lokal, dll)
DATABASE_URL="postgresql://postgres:password@localhost:5432/siapbencana?schema=public"

# ── Server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────
# WAJIB diganti dengan random string panjang saat production!
# Contoh generate: openssl rand -base64 48
JWT_SECRET="ganti-dengan-secret-yang-sangat-panjang-dan-acak"
JWT_EXPIRES_IN="7d"
COOKIE_NAME="sb_token"

# ── CORS ──────────────────────────────────────────────────────────
# URL frontend Next.js (boleh lebih dari satu, dipisah koma)
CORS_ORIGIN="http://localhost:3000"

# ── Seed awal admin (dipakai oleh prisma/seed.ts) ────────────────
SEED_ADMIN_KODE="ADMIN-2025"
SEED_ADMIN_NAMA="Administrator"
SEED_ADMIN_PASSWORD="ganti-password-ini"

# ── Seed password default untuk data contoh (HANYA untuk testing) ─
SEED_KOORDINATOR_PASSWORD="koordinator123"
SEED_RELAWAN_PASSWORD="relawan123"
